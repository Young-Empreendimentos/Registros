# Supabase único — espelho Sienge (vvtympzatclvjaqucebr)
# Tabelas sienge_* (ingestão) + registros_* (app)
SUPABASE_TI_URL=https://vvtympzatclvjaqucebr.supabase.co
SUPABASE_TI_SERVICE_KEY=your-service-role-key
SUPABASE_TI_ANON_KEY=your-anon-key

# Compatível com deploys antigos (opcional — mesmos valores do bloco acima)
NEXT_PUBLIC_SUPABASE_URL=https://vvtympzatclvjaqucebr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Migração one-shot do projeto legado atfsixsamqwndwnfvpdy (opcional)
SUPABASE_LEGACY_URL=https://atfsixsamqwndwnfvpdy.supabase.co
SUPABASE_LEGACY_SERVICE_KEY=your-legacy-service-role-key

# SIENGE API
SIENGE_BASE_URL=https://api.sienge.com.br/youngemp/public/api/v1
SIENGE_USERNAME=your-username
SIENGE_PASSWORD=your-password

# E-mail — Resend (API HTTP, porta 443)
# SMTP direto (Gmail) NÃO funciona no Railway: ele bloqueia as portas SMTP de saída.
# RESEND_API_KEY: criar em https://resend.com → API Keys
# EMAIL_FROM: precisa ser de um domínio VERIFICADO no Resend (Domains → Add Domain → registros DNS)
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=registros@youngempreendimentos.com.br

# Sync API secret (protege endpoints ingest/sync/pipeline)
SYNC_API_SECRET=your-random-secret-here

# URL pública do app (e-mails de credenciais de usuário)
APP_PUBLIC_URL=https://sistemaderegistros.youngempreendimentos.com.br
